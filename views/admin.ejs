<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Admin - Planner 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,600;1,400&family=JetBrains+Mono:wght@300;400;500&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/static/css/main.css">
<style>
  .admin-wrap { max-width: 1100px; padding: 24px; margin: 0 auto; }
  .tbl-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; padding: 20px; margin-top: 24px; overflow: auto; box-shadow: 0 4px 12px var(--shadow); }
  .tbl { width: 100%; border-collapse: collapse; }
  .tbl th, .tbl td { padding: 14px 12px; border-bottom: 1px solid var(--border); text-align: left; font-size: 13px; color: var(--text2); }
  .tbl th { font-family: var(--font-m); font-size: 10px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text3); font-weight: 500; }
  .tbl tr:hover td { background: rgba(255,255,255,0.02); }
  .badge { padding: 3px 8px; border-radius: 20px; font-size: 10px; background: var(--goldgl); color: var(--gold); border: 1px solid rgba(201,168,76,0.3); font-weight: 600; text-transform: uppercase; }
  .u-info { display: flex; align-items: center; gap: 10px; }
  .u-avatar { width: 32px; height: 32px; background: var(--bg4); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 600; color: var(--gold); border: 1px solid var(--border); }
</style>
</head>
<body>

<aside class="sidebar" id="sidebar">
  <div class="sb-brand">
    <div class="sb-logo" onclick="toggleSidebar()">P</div>
    <div class="sb-title">Planner<span>2026</span></div>
  </div>
  <nav class="sb-nav">
    <div class="sb-link" onclick="window.location.href='/?page=planner'"><span class="sb-icon">📋</span><span class="sb-lbl">Planner Semanal</span></div>
    <div class="sb-link" onclick="window.location.href='/?page=calendario'"><span class="sb-icon">📅</span><span class="sb-lbl">Calendário</span></div>
    <div class="sb-link" onclick="window.location.href='/?page=kanban'"><span class="sb-icon">🗂️</span><span class="sb-lbl">Quadro Kanban</span></div>
    <div class="sb-link" onclick="window.location.href='/?page=backlog'"><span class="sb-icon">📌</span><span class="sb-lbl">Backlog</span></div>
    <div class="sb-link" onclick="window.location.href='/?page=rotina'"><span class="sb-icon">🔄</span><span class="sb-lbl">Rotina</span></div>
    <div class="sb-link" onclick="window.location.href='/?page=categorias'"><span class="sb-icon">🏷️</span><span class="sb-lbl">Categorias</span></div>
    <div class="sb-link" onclick="window.location.href='/?page=imprevistos'"><span class="sb-icon">⚡</span><span class="sb-lbl">Imprevistos</span></div>
    <div class="sb-link" onclick="window.location.href='/?page=revisao'"><span class="sb-icon">📊</span><span class="sb-lbl">Revisão Semanal</span></div>
    <% if (currentUser.is_admin) { %>
    <div class="sb-link active"><span class="sb-icon">👑</span><span class="sb-lbl">Admin Panel</span></div>
    <% } %>
    <div class="sb-link" onclick="window.location.href='/logout'"><span class="sb-icon">🚪</span><span class="sb-lbl">Sair (<%= currentUser.nome %>)</span></div>
  </nav>
  <div class="sb-footer">
    <span class="sb-footer-txt">⚓ ADMIN ACCESS</span>
    <div class="theme-btns">
      <button class="theme-btn" id="tb-dark"  onclick="setTheme('dark')"   title="Dark">🌙</button>
      <button class="theme-btn" id="tb-light" onclick="setTheme('light')"  title="Light">☀️</button>
      <button class="theme-btn" id="tb-sys"   onclick="setTheme('system')" title="Sistema">💻</button>
    </div>
  </div>
</aside>

<div class="main-wrap">
  <header class="topbar">
    <button class="tb-menu" onclick="toggleSidebar()">☰</button>
    <div class="tb-ctx">Administração de Usuários</div>
  </header>
  
  <div class="pages">
    <div class="page active" style="overflow:auto">
      <div class="admin-wrap">
        
        <div style="background:var(--bg3); padding:24px; border-radius:12px; border:1px solid var(--border); box-shadow: 0 4px 15px var(--shadow)">
          <h3 style="margin-top:0; font-family:var(--font-d); color:var(--text); font-size:20px; font-weight:400; font-style:italic">Cadastrar Novo Usuário</h3>
          <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap:16px; margin-top:20px;">
            <div>
              <label style="font-size:10px; color:var(--text3); margin-bottom:6px; display:block; text-transform:uppercase; letter-spacing:1px">Nome Completo</label>
              <input type="text" id="n-nome" class="field-in" placeholder="Ex: Rodrigo Melo">
            </div>
            <div>
              <label style="font-size:10px; color:var(--text3); margin-bottom:6px; display:block; text-transform:uppercase; letter-spacing:1px">E-mail Corporativo</label>
              <input type="email" id="n-email" class="field-in" placeholder="ex: jose@email.com">
            </div>
            <div>
              <label style="font-size:10px; color:var(--text3); margin-bottom:6px; display:block; text-transform:uppercase; letter-spacing:1px">Senha Temporária</label>
              <input type="password" id="n-pass" class="field-in" placeholder="Digite uma senha">
            </div>
            <div style="display:flex; align-items:flex-end; padding-bottom:8px;">
              <label class="check-box" style="display:flex; align-items:center; gap:8px; font-size:12px; cursor:pointer; color:var(--text2); user-select:none">
                <input type="checkbox" id="n-admin"> Dar acesso de Administrador
              </label>
            </div>
            <div style="display:flex; align-items:flex-end;">
              <button class="btn-p" onclick="addUser()" style="width:100%; height:38px; font-size:10px; border-radius:6px">CRIAR CONTA</button>
            </div>
          </div>
        </div>

        <div class="tbl-card">
          <table class="tbl">
            <thead>
              <tr>
                <th>Identificação</th>
                <th>Nome</th>
                <th>E-mail</th>
                <th>Nível de Acesso</th>
                <th style="text-align:right">Gerenciamento</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(function(u) { %>
              <tr>
                <td style="font-family:var(--font-m); font-size:11px; color:var(--text3)">#<%= u.id %></td>
                <td>
                   <div class="u-info">
                     <div class="u-avatar"><%= u.nome[0].toUpperCase() %></div>
                     <span style="color:var(--text); font-weight:500"><%= u.nome %></span>
                   </div>
                </td>
                <td><%= u.email %></td>
                <td>
                  <% if (u.is_admin) { %>
                  <span class="badge">Administrador</span>
                  <% } else { %>
                  <span style="opacity:.6; font-size:11px">Colaborador</span>
                  <% } %>
                </td>
                <td style="text-align:right">
                  <div style="display:inline-flex; gap:8px">
                    <button class="btn-g" style="padding:5px 10px; font-size:10px; border-radius:4px" onclick="resetPass(<%= u.id %>)">Alterar Senha</button>
                    <% if (u.id !== currentUser.id) { %>
                    <button class="btn-d" style="padding:5px 10px; font-size:10px; border-radius:4px" onclick="delUser(<%= u.id %>)">Remover</button>
                    <% } %>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

      </div>
    </div>
  </div>
</div>

<script>
  function setTheme(t) {
    if(t==='system') {
      localStorage.removeItem('theme');
      t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    } else {
      localStorage.setItem('theme', t);
    }
    document.body.setAttribute('data-theme', t);
    updateThemeBtns();
  }
  
  function updateThemeBtns() {
    const active = localStorage.getItem('theme') || 'system';
    document.querySelectorAll('.theme-btn').forEach(b => b.classList.remove('active'));
    var el = document.getElementById('tb-' + active);
    if(el) el.classList.add('active');
  }

  const savedTheme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
  document.body.setAttribute('data-theme', savedTheme);
  updateThemeBtns();

  function toggleSidebar() { 
    document.getElementById('sidebar').classList.toggle('collapsed'); 
  }

  function getAdminDialog() {
    var overlay = document.getElementById('dialog-overlay');
    if(!overlay) {
      overlay = document.createElement('div'); overlay.className = 'overlay'; overlay.id = 'dialog-overlay'; overlay.style.zIndex = '10000';
      overlay.innerHTML = '<div class="modal" id="dialog-modal" style="width:340px; text-align:center; padding:24px;">' +
        '<h3 id="dialog-title" style="margin-top:0; margin-bottom:12px; font-family:var(--font-m); font-weight:600; font-size:20px; color:var(--text1)">Aviso</h3>' +
        '<div id="dialog-msg" style="margin-bottom:18px; font-size:14px; color:var(--text2); line-height:1.5;"></div>' +
        '<input type="text" id="dialog-input" class="field-in" style="display:none; margin-bottom:18px; text-align:center; width:100%">' +
        '<div style="display:flex; gap:12px; justify-content:center;">' +
          '<button class="btn-g" id="dialog-cancel" style="display:none; padding:8px 16px; flex:1">Cancelar</button>' +
          '<button class="btn-p" id="dialog-ok" style="padding:8px 16px; flex:1">Confirmar</button>' +
        '</div>' +
      '</div>';
      document.body.appendChild(overlay);
    }
    return {
      overlay: overlay, title: overlay.querySelector('#dialog-title'), msg: overlay.querySelector('#dialog-msg'),
      input: overlay.querySelector('#dialog-input'), btnCancel: overlay.querySelector('#dialog-cancel'), btnOk: overlay.querySelector('#dialog-ok')
    };
  }

  function showAdminDialog(title, msg, defaultVal, isConfirm, callback) {
    var d = getAdminDialog();
    d.title.textContent = title; d.msg.textContent = msg;
    if(defaultVal !== undefined && defaultVal !== null) { d.input.style.display = 'block'; d.input.value = defaultVal; } else { d.input.style.display = 'none'; d.input.value = ''; }
    if(isConfirm) d.btnCancel.style.display = 'block'; else d.btnCancel.style.display = 'none';
    d.overlay.classList.add('open');
    setTimeout(function(){ if(defaultVal !== undefined && defaultVal !== null) d.input.focus(); else d.btnOk.focus(); }, 50);
    d.btnOk.onclick = function() { d.overlay.classList.remove('open'); if(callback) callback(true, d.input.value); };
    d.btnCancel.onclick = function() { d.overlay.classList.remove('open'); if(callback) callback(false, null); };
  }

  function siteAlert(msg) { return new Promise(r => showAdminDialog('Aviso', msg, null, false, r)); }
  function siteConfirm(msg) { return new Promise(r => showAdminDialog('Confirmação', msg, null, true, r)); }
  function sitePrompt(msg, def) { return new Promise(r => showAdminDialog('Entrada', msg, def || '', true, (res, val) => r(res ? val : null))); }

  async function addUser() {
    let nome = document.getElementById('n-nome').value.trim();
    let email = document.getElementById('n-email').value.trim();
    let password = document.getElementById('n-pass').value.trim();
    let is_admin = document.getElementById('n-admin').checked;
    if(!nome || !email || !password) return siteAlert('Preencha todos os campos obrigatórios!');
    let r = await fetch('/api/admin/users', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({nome, email, password, is_admin})});
    if(r.ok) { await siteAlert('Usuário criado com sucesso!'); location.reload(); } else siteAlert((await r.json()).error || 'Erro ao criar usuário');
  }
  
  async function resetPass(uid) {
    let p = await sitePrompt('Digite a nova senha para o usuário:');
    if(!p) return;
    let r = await fetch(`/api/admin/users/${uid}/reset-password`, {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({password:p})});
    if(r.ok) siteAlert('Senha atualizada com sucesso!');
  }

  async function delUser(uid) {
    if(!(await siteConfirm('Certeza que deseja excluir permanentemente este usuário?'))) return;
    let r = await fetch(`/api/admin/users/${uid}`, {method:'DELETE'});
    if(r.ok) location.reload(); else siteAlert('Erro ao excluir usuário');
  }
</script>
</body>
</html>
