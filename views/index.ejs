<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Planner 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,600;1,400&family=JetBrains+Mono:wght@300;400;500&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/static/css/main.css">
<link rel="stylesheet" href="/static/css/chat.css">
<link rel="stylesheet" href="/static/css/config.css">
<link rel="manifest" href="/static/manifest.json">
<meta name="theme-color" content="#0d1117">
</head>
<body>

<aside class="sidebar" id="sidebar">
  <div class="sb-brand">
    <div class="sb-logo" onclick="toggleSidebar()">P</div>
    <div class="sb-title">Planner<span>2026</span></div>
  </div>
  <nav class="sb-nav">
    <div class="sb-link active" data-page="planner" onclick="goTo('planner')"><span class="sb-icon">📋</span><span class="sb-lbl">Planner Semanal</span></div>
    <div class="sb-link" data-page="calendario" onclick="goTo('calendario')"><span class="sb-icon">📅</span><span class="sb-lbl">Calendário</span></div>
    <div class="sb-link" data-page="kanban" onclick="goTo('kanban')"><span class="sb-icon">🗂️</span><span class="sb-lbl">Quadro Kanban</span></div>
    <div class="sb-link" data-page="backlog" onclick="goTo('backlog')"><span class="sb-icon">☑️</span><span class="sb-lbl">To Do</span><span class="sb-badge" id="bdg-bl"></span></div>
    <div class="sb-link" data-page="rotina" onclick="goTo('rotina')"><span class="sb-icon">🔄</span><span class="sb-lbl">Rotina</span></div>
    <div class="sb-link" data-page="categorias" onclick="goTo('categorias')"><span class="sb-icon">🏷️</span><span class="sb-lbl">Categorias</span></div>
    <div class="sb-link" data-page="imprevistos" onclick="goTo('imprevistos')"><span class="sb-icon">⚡</span><span class="sb-lbl">Imprevistos</span><span class="sb-badge red" id="bdg-imp"></span></div>
    <div class="sb-link" data-page="revisao" onclick="goTo('revisao')"><span class="sb-icon">📊</span><span class="sb-lbl">Revisão Semanal</span></div>
    <div class="sb-link" data-page="canvas" onclick="goTo('canvas')"><span class="sb-icon">🗒️</span><span class="sb-lbl">Notas / Canvas</span></div>
    <div class="sb-link" data-page="configuracoes" onclick="goTo('configuracoes')"><span class="sb-icon">⚙️</span><span class="sb-lbl">Configurações</span></div>
    <% if (currentUser.is_admin) { %>
    <div class="sb-link" onclick="window.location.href='/admin'"><span class="sb-icon">👑</span><span class="sb-lbl">Admin Panel</span></div>
    <% } %>
    <div class="sb-link" onclick="window.location.href='/logout'"><span class="sb-icon">🚪</span><span class="sb-lbl">Sair (<%= currentUser.nome %>)</span></div>
  </nav>
  <div class="sb-footer">
    <span class="sb-footer-txt">⚓ Permissão</span>
    <div class="theme-btns">
      <button class="theme-btn" id="tb-dark"  onclick="setTheme('dark')"   title="Dark">🌙</button>
      <button class="theme-btn" id="tb-light" onclick="setTheme('light')"  title="Light">☀️</button>
      <button class="theme-btn" id="tb-sys"   onclick="setTheme('system')" title="Sistema">💻</button>
    </div>
  </div>
</aside>

<div class="main-wrap">
  <header class="topbar">
    <button class="tb-menu" onclick="toggleSidebar()">☰</button>
    <div class="tb-ctx" id="tb-ctx">Planner Semanal</div>
    <div class="tb-wnav" id="tb-wnav">
      <button class="nav-btn" onclick="prevWeek()">‹</button>
      <div class="tb-wlbl" id="tb-wlbl">—</div>
      <button class="nav-btn" onclick="nextWeek()">›</button>
      <button class="nav-btn today" onclick="goToday()">Hoje</button>
    </div>
    <div style="display:flex;align-items:center;gap:8px;position:relative">
      <button class="tb-alert-btn" id="tb-alert-btn" onclick="toggleAlerts()" title="Alertas">
        🔔<span class="alert-badge" id="alert-badge" style="display:none">0</span>
      </button>
      <div class="alerts-panel" id="alerts-panel" style="display:none"></div>
      <button class="btn-p" onclick="openAddModal()">+ Adicionar</button>
    </div>
  </header>

  <div class="pages">

    <!-- PLANNER -->
    <div class="page active" id="page-planner">
      <div class="planner-layout">
        <div class="planner-center">
          <div class="mobile-day-strip" id="mobile-day-strip"></div>
          <div id="grade-hdr" class="grade-hdr"></div>
          <div id="grade-body" class="grade-body"></div>
        </div>
        <div class="planner-right" id="planner-right">
          <div class="pr-tabs">
            <button class="pr-collapse-btn" id="pr-collapse-btn" onclick="toggleRightSidebar()" title="Recolher painel">«</button>
            <button class="pr-tab active" onclick="switchPrTab('bl',this)"    title="To Do">☑️</button>
            <button class="pr-tab"        onclick="switchPrTab('rot',this)"   title="Rotina">🔄</button>
            <button class="pr-tab"        onclick="switchPrTab('imp',this)"   title="Imprevistos">⚡</button>
            <button class="pr-tab"        onclick="switchPrTab('stats',this)" title="Progresso">📊</button>
          </div>
          <div class="pr-panels">
            <div class="pr-panel active" id="pr-bl">
              <div class="pr-filter" id="pr-filter"></div>
              <div class="pr-list" id="pr-bl-list"></div>
            </div>
            <div class="pr-panel" id="pr-rot">
              <div class="pr-list" id="pr-rot-list"></div>
            </div>
            <div class="pr-panel" id="pr-imp">
              <div class="pr-imp-form" id="pr-imp-form"></div>
              <div class="pr-list" id="pr-imp-list"></div>
            </div>
            <div class="pr-panel" id="pr-stats">
              <div class="pr-list" id="pr-stats-list" style="padding:12px"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- CALENDÁRIO -->
    <div class="page" id="page-calendario">
      <div class="cal-wrap">
        <div class="cal-nav">
          <button class="nav-btn" onclick="calPrev()">‹</button>
          <div class="cal-lbl" id="cal-lbl">—</div>
          <button class="nav-btn" onclick="calNext()">›</button>
        </div>
        <div class="cal-legend" id="cal-legend"></div>
        <div class="cal-grid" id="cal-grid"></div>
      </div>
    </div>

    <!-- TO DO -->
    <div class="page" id="page-backlog">
      <div class="page-inner">
        <div class="page-search-bar">
          <input class="search-input" id="bl-search" type="text" placeholder="🔍  Buscar em To Do..." oninput="renderBacklog()">
          <select class="field-sel search-sel" id="bl-urg-filter" onchange="renderBacklog()">
            <option value="">Urgência</option>
            <option value="h">🔴 Urgente</option>
            <option value="m">🟡 Normal</option>
            <option value="l">🟢 Baixo</option>
          </select>
          <select class="field-sel search-sel" id="bl-status-filter" onchange="renderBacklog()">
            <option value="">Status</option>
            <option value="aberto">Abertos</option>
            <option value="concluido">Concluídos</option>
          </select>
        </div>
        <div class="page-filters" id="bl-filters"></div>
        <div class="tbl-wrap">
          <table class="data-tbl">
              <thead><tr>
                <th style="width:32px"></th>
                <th style="width:36px"></th>
                <th onclick="sortTable('backlog','id')" style="cursor:pointer">ID ▲▼</th>
                <th onclick="sortTable('backlog','titulo')" style="cursor:pointer">Título ▲▼</th>
                <th onclick="sortTable('backlog','categoria_id')" style="cursor:pointer">Categoria ▲▼</th>
                <th onclick="sortTable('backlog','urgencia')" style="cursor:pointer">Urgência ▲▼</th>
                <th onclick="sortTable('backlog','prazo')" style="cursor:pointer">Prazo ▲▼</th>
                <th style="width:80px">Ações</th>
              </tr></thead>
            <tbody id="bl-tbody"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ROTINA -->
    <div class="page" id="page-rotina">
      <div class="page-inner">
        <div class="page-search-bar">
          <input class="search-input" id="rot-search" type="text" placeholder="🔍  Buscar rotinas..." oninput="renderRotinaPage()">
          <select class="field-sel search-sel" id="rot-cat-filter" onchange="renderRotinaPage()">
            <option value="">Categoria</option>
          </select>
          <select class="field-sel search-sel" id="rot-dia-filter" onchange="renderRotinaPage()">
            <option value="">Dia</option>
            <option value="0">Segunda</option><option value="1">Terça</option>
            <option value="2">Quarta</option><option value="3">Quinta</option>
            <option value="4">Sexta</option><option value="5">Sábado</option>
            <option value="6">Domingo</option>
          </select>
          <select class="field-sel search-sel" id="rot-status-filter" onchange="renderRotinaPage()">
            <option value="">Status</option>
            <option value="ativo">Ativas</option>
            <option value="pausado">Pausadas</option>
          </select>
        </div>
        <div class="rotina-grid" id="rot-grid"></div>
      </div>
    </div>

    <!-- CATEGORIAS -->
    <div class="page" id="page-categorias">
      <div class="page-inner">
        <div class="cats-grid" id="cats-grid"></div>
      </div>
    </div>

    <!-- KANBAN -->
    <div class="page" id="page-kanban">
      <div class="kanban-header">
        <div class="kanban-controls">
          <label class="check-box" style="font-size:11px; color:var(--text2); display:flex; align-items:center; gap:6px; cursor:pointer">
            <input type="checkbox" id="kanban-group-cat" onchange="renderKanban()"> Agrupar por Categoria (Raias)
          </label>
        </div>
      </div>
      <div class="kanban-board-container">
        <div class="kanban-board" id="kanban-board"></div>
        <button class="kanban-add-col" onclick="addNewKanbanColumn()">+ Nova Coluna</button>
      </div>
    </div>

    <!-- IMPREVISTOS -->
    <div class="page" id="page-imprevistos">
      <div class="page-inner" style="max-width:720px">
        <div class="imp-add-block">
          <label class="ml">Novo imprevisto</label>
          <textarea class="field-ta" id="imp-ta" rows="2" placeholder="Descreva o imprevisto..."></textarea>
          <div class="imp-row">
            <select class="field-sel" id="imp-urg" style="flex:1">
              <option value="h">🔴 Urgente</option>
              <option value="m" selected>🟡 Normal</option>
              <option value="l">🟢 Baixo</option>
            </select>
            <button class="btn-p" onclick="addImpPg()">+ Adicionar</button>
          </div>
        </div>
        <div class="page-search-bar" style="margin:10px 0 4px 0">
          <input class="search-input" id="imp-search" type="text" placeholder="🔍  Buscar imprevistos..." oninput="renderImpPg()">
          <select class="field-sel search-sel" id="imp-status-filter" onchange="renderImpPg()">
            <option value="">Status</option>
            <option value="aberto">Abertos</option>
            <option value="resolvido">Resolvidos</option>
          </select>
        </div>
        <div style="display:flex; gap:15px; font-family:var(--font-m); font-size:9px; color:var(--text3); border-bottom:1px solid var(--border); padding-bottom:5px; margin:10px 0; cursor:pointer">
          <span onclick="sortTable('imprevistos','id')" style="width:50px">ID ▲▼</span>
          <span onclick="sortTable('imprevistos','texto')" style="flex:1">Descrição ▲▼</span>
          <span onclick="sortTable('imprevistos','data')" style="width:80px">Data ▲▼</span>
          <span onclick="sortTable('imprevistos','urgencia')" style="width:60px">Urg ▲▼</span>
        </div>
        <div id="imp-list"></div>
      </div>
    </div>

    <!-- REVISÃO -->
    <div class="page" id="page-revisao">
      <div class="page-inner" style="max-width:900px">
        <div class="rev-header" id="rev-header">
          <div style="font-family:var(--font-m);font-size:9px;color:var(--text3);letter-spacing:2px;text-transform:uppercase">Revisão Semanal</div>
          <div style="font-size:22px;font-weight:600;margin-top:4px" id="rev-week-lbl">—</div>
        </div>
        <!-- Stats -->
        <div class="rev-section">
          <div class="rev-section-title">📊 Progresso da Semana</div>
          <div id="rev-stats-grid"></div>
        </div>
        <!-- Reflexão -->
        <div class="rev-section">
          <div class="rev-section-title">📝 Reflexão</div>
          <div id="rev-form"></div>
          <button class="btn-p" style="width:100%;padding:11px;margin-top:8px" onclick="saveRevisao()">💾 Salvar Reflexão</button>
          <div id="rev-saved-msg" style="font-family:var(--font-m);font-size:9px;color:var(--green);margin-top:6px;text-align:center"></div>
        </div>
        <!-- Planos de ação -->
        <div class="rev-section">
          <div class="rev-section-title" style="display:flex;align-items:center;justify-content:space-between">
            <span>🎯 Planos de Ação</span>
            <button class="btn-p" style="font-size:10px;padding:6px 14px" onclick="openNovoPlano()">+ Novo Plano</button>
          </div>
          <div id="rev-planos-list"></div>
          <!-- Form inline novo plano -->
          <div id="rev-plano-form" style="display:none;background:var(--bg3);border-radius:8px;padding:14px;margin-top:10px">
            <div class="mrow">
              <div class="mf" style="flex:2">
                <label class="ml">Ação</label>
                <input class="field-in" id="pf-titulo" placeholder="O que fazer?">
              </div>
              <div class="mf">
                <label class="ml">Categoria</label>
                <select class="field-sel" id="pf-cat"></select>
              </div>
            </div>
            <div class="mrow">
              <div class="mf">
                <label class="ml">Prazo</label>
                <input class="field-in" id="pf-prazo" type="date">
              </div>
              <div class="mf">
                <label class="ml">Urgência</label>
                <select class="field-sel" id="pf-urg">
                  <option value="h">🔴 Urgente</option>
                  <option value="m" selected>🟡 Normal</option>
                  <option value="l">🟢 Baixo</option>
                </select>
              </div>
            </div>
            <div style="display:flex;gap:8px;margin-top:8px">
              <button class="btn-p" style="flex:1" onclick="salvarPlano()">Salvar Plano</button>
              <button class="btn-g" onclick="fecharNovoPlano()">Cancelar</button>
              <button class="btn-d" style="font-size:10px" onclick="promoverParaBacklog()" title="Criar no To Do também">☑️ Promover p/ To Do</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- CANVAS / NOTAS -->
    <div class="page" id="page-canvas">
      <!-- Top bar: boards + actions + zoom -->
      <div class="canvas-topbar">
        <div class="canvas-boards-list" id="canvas-boards-list"></div>
        <button class="cv-new-board-btn" onclick="canvasNewBoard()" title="Novo Board">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Board
        </button>
        <button class="cv-parking-btn" id="cv-parking-btn" onclick="canvasToggleParkingPanel()" title="Parking Lot — notas em espera">
          &#128143; <span id="cv-parking-badge" class="cv-parking-badge">0</span>
        </button>
        <div class="cv-topbar-divider"></div>
        <!-- Format bars (context-sensitive) -->
        <div class="cv-fmt-bar" id="cv-fmt-bar" style="display:none">
          <button class="ct-fmt-btn" id="ctf-bold"      onclick="canvasFmt('bold')"      title="Negrito (Ctrl+B)"><b>B</b></button>
          <button class="ct-fmt-btn" id="ctf-italic"    onclick="canvasFmt('italic')"    title="Itálico (Ctrl+I)"><i>I</i></button>
          <button class="ct-fmt-btn" id="ctf-underline" onclick="canvasFmt('underline')" title="Sublinhado (Ctrl+U)"><u>U</u></button>
          <button class="ct-fmt-btn" id="ctf-link"      onclick="canvasFmtLink()"        title="Adicionar Link (Ctrl+K)">&#128279;</button>
          <div class="cv-fmt-sep"></div>
          <select class="ct-fmt-sel" id="ct-font-family" onchange="canvasFmtFont(this.value)" title="Fonte">
            <option value="inherit">Padrão</option>
            <option value="&apos;Segoe UI&apos;,sans-serif">Segoe UI</option>
            <option value="Georgia,serif">Georgia</option>
            <option value="&apos;Courier New&apos;,monospace">Mono</option>
            <option value="Arial,sans-serif">Arial</option>
          </select>
          <select class="ct-fmt-sel" id="ct-font-size" onchange="canvasFmtSize(this.value)" title="Tamanho">
            <option value="10">10</option><option value="12">12</option>
            <option value="14" selected>14</option><option value="18">18</option>
            <option value="24">24</option><option value="32">32</option>
            <option value="48">48</option>
          </select>
          <input type="color" class="ct-fmt-color" id="ct-text-color" onchange="canvasFmtColor(this.value)" title="Cor do texto" value="#000000">
        </div>
        <div class="cv-fmt-bar" id="ct-shape-fmt" style="display:none">
          <label class="ct-fmt-lbl">Fundo</label>
          <input type="color" class="ct-fmt-color" id="ct-shape-fundo" onchange="canvasShapeFmtColor('fundo',this.value)" value="#3b82f6">
          <label class="ct-fmt-lbl">Borda</label>
          <input type="color" class="ct-fmt-color" id="ct-shape-borda" onchange="canvasShapeFmtColor('borda',this.value)" value="#1d4ed8">
          <label class="ct-fmt-lbl">Esp.</label>
          <select class="ct-fmt-sel" id="ct-shape-esp" onchange="canvasShapeFmtEsp(this.value)">
            <option value="0">0px</option><option value="1">1px</option>
            <option value="2" selected>2px</option><option value="3">3px</option>
            <option value="4">4px</option>
          </select>
        </div>
        <div class="cv-fmt-bar" id="cv-pen-fmt" style="display:none">
          <label class="ct-fmt-lbl">Cor</label>
          <input type="color" class="ct-fmt-color" id="cv-pen-color" onchange="S.canvasPenColor=this.value" value="#ffffff">
          <label class="ct-fmt-lbl">Esp.</label>
          <select class="ct-fmt-sel" id="cv-pen-width" onchange="S.canvasPenWidth=Number(this.value)">
            <option value="2">2px</option><option value="3" selected>3px</option>
            <option value="5">5px</option><option value="8">8px</option>
            <option value="12">12px</option>
          </select>
        </div>
        <!-- Right-side controls -->
        <div class="cv-topbar-right">
          <div class="cv-search-wrap">
            <svg class="cv-search-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <input class="cv-search-input" id="cv-search-input" type="text" placeholder="Buscar..." oninput="canvasSearchNotes(this.value)" autocomplete="off">
            <div class="cv-search-results" id="cv-search-results"></div>
          </div>
          <div class="cv-ctrl-group" style="position:relative">
            <button class="cv-ctrl-btn" onclick="canvasToggleBgPicker()" title="Fundo do canvas">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            </button>
            <div class="cv-bg-panel" id="cv-bg-panel" style="display:none">
              <div class="cv-bg-panel-title">Fundo</div>
              <div class="cv-bg-opts">
                <button class="cv-bg-opt active" data-bg="dots"  onclick="canvasSetBg('dots')"  title="Pontos">&#10815;</button>
                <button class="cv-bg-opt" data-bg="grid"  onclick="canvasSetBg('grid')"  title="Grade">&#8862;</button>
                <button class="cv-bg-opt" data-bg="lines" onclick="canvasSetBg('lines')" title="Linhas">&#8801;</button>
                <button class="cv-bg-opt" data-bg="plain" onclick="canvasSetBg('plain')" title="Limpo">&#9634;</button>
              </div>
            </div>
          </div>
          <button class="cv-ctrl-btn" onclick="canvasFitAll()" title="Ajustar tudo na tela">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>
          </button>
          <div class="ct-zoom-ctrl">
            <button onclick="canvasZoomChange(-0.1)" title="Reduzir zoom">−</button>
            <span id="ct-zoom-label">100%</span>
            <button onclick="canvasZoomChange(0.1)" title="Aumentar zoom">+</button>
            <button onclick="canvasZoomReset()" title="Reset zoom" style="font-size:10px;padding:2px 6px">&#8861;</button>
          </div>
        </div>
      </div>
      <!-- Body: vertical toolbar + canvas area -->
      <div class="canvas-body" id="canvas-body">
        <!-- Vertical toolbar -->
        <div class="cvt" id="canvas-vtoolbar">
          <button class="cvt-btn active" data-tool="select" onclick="canvasSetTool('select')" title="Selecionar (V)">
            <svg width="17" height="17" viewBox="0 0 18 18"><path d="M2 1.5l14 8.5-7.5 2-2 7.5z" fill="currentColor"/></svg>
            <span class="cvt-lbl">Cursor</span>
          </button>
          <button class="cvt-btn" data-tool="pan" onclick="canvasSetTool('pan')" title="Mover (H)">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 11V8a2 2 0 0 0-4 0v3M14 8V5a2 2 0 0 0-4 0v3M10 8V6a2 2 0 0 0-4 0v8l-2-2a2 2 0 0 0-2 2l4 6h12v-6a4 4 0 0 0-4-4z"/></svg>
            <span class="cvt-lbl">Mover</span>
          </button>
          <div class="cvt-sep"></div>
          <button class="cvt-btn" data-tool="note" onclick="canvasSetTool('note')" title="Nota sticky (N)">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
            <span class="cvt-lbl">Nota</span>
          </button>
          <button class="cvt-btn" data-tool="doc" onclick="canvasSetTool('doc')" title="Documento (D)">
