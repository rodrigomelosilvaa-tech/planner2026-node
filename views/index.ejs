        <div class="cfg-card">
          <div class="cfg-card-header">
            <span class="cfg-card-icon">🔔</span>
            <div>
              <div class="cfg-card-ttl">Notificações</div>
              <div class="cfg-card-sub">Receba alertas no celular e no computador quando uma atividade estiver chegando</div>
            </div>
            <label class="cfg-toggle" title="Ativar/desativar notificações">
              <input type="checkbox" id="cfg-notif-ativa" onchange="cfgToggleNotif(this.checked)">
              <span class="cfg-toggle-track"><span class="cfg-toggle-thumb"></span></span>
            </label>
          </div>
          <div class="cfg-notif-body" id="cfg-notif-body">
            <div class="cfg-row">
              <label class="cfg-lbl">Avisar com antecedência</label>
              <div class="cfg-row-ctrl">
                <select class="cfg-sel" id="cfg-notif-min" onchange="cfgSaveMinutos(this.value)">
                  <option value="1">1 minuto</option>
                  <option value="3">3 minutos</option>
                  <option value="5" selected>5 minutos</option>
                  <option value="10">10 minutos</option>
                  <option value="15">15 minutos</option>
                  <option value="30">30 minutos</option>
                </select>
              </div>
            </div>
            <div class="cfg-row">
              <div class="cfg-lbl">
                Som de notificação
                <span class="cfg-lbl-sub">Toca um som quando o alerta disparar</span>
              </div>
              <label class="cfg-toggle-sm">
                <input type="checkbox" id="cfg-notif-som" onchange="cfgSaveSom(this.checked)">
                <span class="cfg-toggle-track"><span class="cfg-toggle-thumb"></span></span>
              </label>
            </div>
            <div class="cfg-row" id="cfg-row-som-tipo">
              <div class="cfg-lbl">
                Tipo de som
                <span class="cfg-lbl-sub">Escolha o tom do alerta</span>
              </div>
              <div class="cfg-row-ctrl">
                <select class="cfg-sel" id="cfg-notif-som-tipo" onchange="cfgSaveSomTipo(this.value)">
                  <option value="sino">🔔 Sino</option>
                  <option value="duplo">🔔🔔 Duplo</option>
                  <option value="suave">🎵 Suave</option>
                  <option value="urgente">🚨 Urgente</option>
                  <option value="pop">💬 Pop</option>
                </select>
                <button class="cfg-preview-btn" onclick="cfgPreviewSom()" title="Testar som">
                  ▶ Testar
                </button>
              </div>
            </div>
            <div class="cfg-notif-status" id="cfg-notif-status">
              <span id="cfg-notif-status-txt">Verificando permissão...</span>
              <button class="btn-p" id="cfg-notif-perm-btn" onclick="cfgPedirPermissao()" style="display:none;font-size:10px;padding:5px 12px">Permitir notificações</button>
            </div>
          </div>
        </div>

        <!-- Sobre / versão -->
        <div class="cfg-card">
          <div class="cfg-card-header">
            <span class="cfg-card-icon">ℹ️</span>
            <div>
              <div class="cfg-card-ttl">Sobre o Planner 2026</div>
              <div class="cfg-card-sub">Versão 2.0 — Planner pessoal de rotinas, tarefas e metas</div>
            </div>
          </div>
        </div>
      </div>
