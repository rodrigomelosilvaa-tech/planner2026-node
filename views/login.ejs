<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Login - Planner 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,600;1,400&family=JetBrains+Mono:wght@300;400;500&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/static/css/main.css">
<style>
body { display: flex; align-items: center; justify-content: center; height: 100vh; background: var(--bg1); }
.login-box { background: var(--bg2); padding: 30px; border-radius: 8px; width: 100%; max-width: 320px; box-shadow: var(--shadow); border: 1px solid var(--border); }
.login-title { font-size: 24px; font-weight: 600; text-align: center; margin-bottom: 20px; }
.login-title span { color: var(--gold); font-family: var(--font-s); font-style: italic; }
.login-error { color: var(--red); font-size: 11px; text-align: center; margin-bottom: 10px; }
.login-btn { width: 100%; padding: 12px; margin-top: 20px; font-size: 13px; }
</style>
</head>
<body data-theme="dark">
<div class="login-box">
  <div class="login-title">Planner<span>2026</span></div>
  <% if (error) { %>
  <div class="login-error"><%= error %></div>
  <% } %>
  <form method="POST">
    <div style="margin-bottom:12px;">
      <label class="ml">E-mail</label>
      <input type="email" name="email" class="field-in" required placeholder="seu@email.com">
    </div>
    <div style="margin-bottom:12px;">
      <label class="ml">Senha</label>
      <input type="password" name="password" class="field-in" required placeholder="••••••••">
    </div>
    <button type="submit" class="btn-p login-btn">Entrar</button>
  </form>
</div>
<script>
  if(localStorage.getItem('theme')) {
    document.body.setAttribute('data-theme', localStorage.getItem('theme'));
  }
</script>
</body>
</html>
